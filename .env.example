NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=myapp_db
DB_USER=root
DB_PASSWORD=

# JWT Secrets (CRITICAL: Use strong values, min 32 characters each)
JWT_ACCESS_SECRET=your_long_random_access_secret_minimum_32_characters_here_12345678
JWT_REFRESH_SECRET=your_long_random_refresh_secret_minimum_32_characters_here_87654321
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=your_long_random_session_secret_minimum_32_characters_here_abcdefgh
SESSION_MAX_AGE=604800000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
